# Base Wallet (for x402 micropayments)
BASE_PRIVATE_KEY=
BASE_RPC_URL=https://mainnet.base.org

# Risk Parameters
MAX_DRAWDOWN_PCT=15
DAILY_LOSS_LIMIT_PCT=5
MAX_POSITION_PCT=10
MAX_SLIPPAGE_PCT=2
MIN_TRADE_COOLDOWN_SEC=300
