# TWAK (Trust Wallet Agent Kit)
TWAK_API_KEY=
TWAK_WALLET_MODE=autonomous

# CMC API
CMC_API_KEY=

# BNB Agent SDK
BNB_AGENT_PRIVATE_KEY=
BNB_AGENT_NETWORK=bsc-mainnet

# BSC Wallet (for trading)
